{
  "name": "obsidian-static-publisher",
  "version": "0.1.0",
  "description": "Publish from Obsidian to a static-site GitHub repo with S3-compatible asset uploads.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "static-site",
    "hugo",
    "publishing",
    "s3",
    "r2",
    "cms"
  ],
  "author": "Anurag Vishwakarma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20"
  }
}
