{
  "name": "obsidian-forge",
  "version": "2026.05.26",
  "description": "Publish from Obsidian to a static-site GitHub repo with S3-compatible asset uploads.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run test && npm run build",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "static-site",
    "hugo",
    "publishing",
    "s3",
    "r2",
    "cms"
  ],
  "author": "Anurag Vishwakarma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20"
  }
}
